email:
  imap_server: imap.gmail.com
  imap_port: 993
  username: ""                    # Your Gmail address
  password: ""                    # Gmail App Password (NOT your regular password)
  poll_interval_seconds: 120      # How often to check for new emails
  subject_filter: ""              # Only emails with this subject are processed. Empty = accept all subjects.
  allowed_senders: []             # Empty = accept from all senders. Example: ["mom@example.com", "dad@example.com"]

  # ── Hebrew reply summary (optional) ─────────────────────────────────
  # When enabled, after each email is processed the bridge sends a friendly
  # Hebrew reply back to the sender summarising what reached the frame and
  # explaining (in family-readable terms) anything that didn't. The reply
  # threads as a "Re:" so it lands inside the same conversation in Gmail.
  # Disabled by default — existing installs are not affected.
  reply_with_summary: false       # Set to true to enable summary replies.
  smtp_server: smtp.gmail.com     # SMTP host (used only when reply_with_summary is true).
  smtp_port: 587                  # 587 = STARTTLS (Gmail default). 465 = SMTPS.
  smtp_from_name: "Frameo"        # Display name shown in the reply's From: header.

frame:
  adb_ip: ""                      # Frame's WiFi IP (set automatically by configure.py)
  adb_port: 5555
  photo_path: "/sdcard/DCIM/"     # Frameo reads photos/videos from here
  resolution_width: 1280          # Auto-detected by configure.py via `adb shell wm size`
  resolution_height: 800
  push_timeout: 60                # Seconds to wait for `adb push` before giving up.
                                  # Increase for very large videos or slow WiFi (e.g. 120).

processing:
  # Image settings
  max_file_size_mb: 2
  jpeg_quality: 95
  strip_exif: true
  convert_heic: true

  # Video settings
  accept_videos: true                 # Set to false to ignore video attachments
  max_video_duration_seconds: 10      # Videos longer than this are trimmed. WARNING: Frameo frames have
                                      # different max durations — typically 10-15 seconds. Check your
                                      # frame's specifications. If unsure, start with 10.
  video_max_file_size_mb: 20          # Max output video file size

# Google Photos sync (optional)
# Syncs photos pushed to the frame to a shared Google Photos album for viewing.
# Family members can view the album via a shared link — no app install needed.
# Requires a Google Cloud project with the Photos Library API enabled.
# Run `python google_photos.py --auth` once to authorize.
google_photos:
  enabled: false
  credentials_file: "credentials.json"    # OAuth2 client credentials from Google Cloud Console
  album_name: "Frameo Photos"             # Album name (created automatically if it doesn't exist)
  full_sync_time: "03:00"                 # Daily full sync with frame (24h format, e.g. "03:00")
  archive_retention_days: 7               # Delete archived files after this many days
                                          # (only files confirmed uploaded to Google Photos).
                                          # Set to 0 to keep forever.
